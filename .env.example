# NuroApp — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Anthropic API ────────────────────────────────────────────────────────────
# Required for AI-powered card generation.
# Get your key at: https://console.anthropic.com/
VITE_ANTHROPIC_API_KEY=sk-ant-...

# ── AI Model Config ───────────────────────────────────────────────────────────
# Model to use for card generation. Defaults to claude-sonnet-4-6 if unset.
VITE_CLAUDE_MODEL=claude-sonnet-4-6

# Max tokens per card generation call (default: 1024)
VITE_CLAUDE_MAX_TOKENS=1024

# ── Feature Flags ─────────────────────────────────────────────────────────────
# Set to "true" to use real LLM calls; "false" forces mock data (for demos).
VITE_USE_REAL_AI=true
